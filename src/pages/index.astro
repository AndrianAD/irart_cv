---
import { readdirSync } from "node:fs";
import { join, extname } from "node:path";
import BaseLayout from "../layouts/BaseLayout.astro";
import GallerySection from "../components/GallerySection.astro";
import portfolio from "../data/portfolio.json";

const base =
  import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

const asset = (path: string) => `${base}${path.replace(/^\//, "")}`;

const pageTitle = `${portfolio.site.title} — ${portfolio.site.tagline}`;
const desc = portfolio.site.heroLead;

const IMAGE_EXTS = new Set([".jpg", ".jpeg", ".png"]);

function scanGallery(categoryId: string) {
  const dir = join(process.cwd(), "public", "galleries", categoryId);
  try {
    return readdirSync(dir)
      .filter((f) => IMAGE_EXTS.has(extname(f).toLowerCase()))
      .sort()
      .map((f) => ({ file: `galleries/${categoryId}/${f}`, alt: "" }));
  } catch {
    return [];
  }
}
---

<BaseLayout title={pageTitle} description={desc}>
  <header class="site-header">
    <div class="site-header__inner">
      <a class="brand" href="#top" id="top">{portfolio.site.title}</a>
      <nav class="nav" id="main-nav" aria-label="Основна навігація">
        {
          portfolio.categories.map((c) => (
            <a href={`#section-${c.id}`}>{c.title}</a>
          ))
        }
        <a href="#section-about">Про мене</a>
        <a href="#section-contact">Контакти</a>
      </nav>
      <button class="nav-toggle" aria-expanded="false" aria-controls="main-nav" aria-label="Меню">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </header>

  <script>
    const toggle = document.querySelector<HTMLButtonElement>(".nav-toggle");
    const nav = document.querySelector<HTMLElement>(".nav");
    if (toggle && nav) {
      toggle.addEventListener("click", () => {
        const open = toggle.getAttribute("aria-expanded") === "true";
        toggle.setAttribute("aria-expanded", String(!open));
        nav.classList.toggle("is-open", !open);
      });
      nav.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
          toggle.setAttribute("aria-expanded", "false");
          nav.classList.remove("is-open");
        });
      });
    }
  </script>

  <section class="hero" aria-labelledby="hero-heading">
    <div class="hero__media" aria-hidden="true">
      <img src={asset(portfolio.heroImage)} alt="" width="1920" height="1080" fetchpriority="high" />
    </div>
    <div class="hero__veil" aria-hidden="true"></div>
    <div class="hero__content">
      <p class="hero__kicker">{portfolio.site.tagline}</p>
      <h1 class="hero__title" id="hero-heading">{portfolio.site.title}</h1>
      <p class="hero__lead">{portfolio.site.heroLead}</p>
      <div class="hero__actions">
        <a class="btn btn--primary" href={`#section-${portfolio.categories[0]?.id ?? "portrait"}`}
          >Портфоліо</a
        >
        <a class="btn btn--ghost" href="#section-contact">Звʼязатися</a>
      </div>
    </div>
  </section>

  {
    portfolio.categories.map((cat) => (
      <GallerySection
        categoryId={cat.id}
        title={cat.title}
        intro={cat.intro}
        items={scanGallery(cat.id)}
        baseUrl={base}
        grid={cat.grid === "instagram" ? "instagram" : undefined}
      />
    ))
  }

  <section class="section" id="section-about" aria-labelledby="about-heading" data-reveal>
    <div class="about-block">
      <h2 id="about-heading">{portfolio.about.title}</h2>
      {portfolio.about.paragraphs.map((p) => <p>{p}</p>)}
    </div>
  </section>

  <section class="section" id="section-contact" aria-labelledby="contact-heading" data-reveal>
    <header class="section__head">
      <h2 class="section__title" id="contact-heading">Контакти</h2>
      <p class="section__intro">Напишіть — обговоримо ідею, терміни та формат зйомки.</p>
    </header>
    <div class="contact-grid">
      <a class="contact-card contact-card--link" href={`tel:${portfolio.contact.phone}`}>
        <svg class="contact-card__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.07 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <div>
          <span>Телефон</span>
          <strong>{portfolio.contact.phone}</strong>
        </div>
      </a>
      <a class="contact-card contact-card--link" href={portfolio.contact.telegram} rel="noopener noreferrer" target="_blank">
        <svg class="contact-card__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12L7.19 13.367l-2.96-.924c-.643-.204-.657-.643.136-.953l11.57-4.461c.537-.194 1.006.131.958.192z"/></svg>
        <div>
          <span>Telegram</span>
          <strong>Написати</strong>
        </div>
      </a>
      <a class="contact-card contact-card--link" href={portfolio.contact.instagram} rel="noopener noreferrer" target="_blank">
        <svg class="contact-card__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
        <div>
          <span>Instagram</span>
          <strong>Профіль</strong>
        </div>
      </a>
    </div>
  </section>

  <footer class="site-footer">
    <p>
      © <span id="y"></span>
      {portfolio.site.title}. Усі права застережено.
    </p>
  </footer>

  <script is:inline>
    document.getElementById("y").textContent = new Date().getFullYear();
  </script>
</BaseLayout>
