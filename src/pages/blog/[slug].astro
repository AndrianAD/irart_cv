---
import { getCollection } from "astro:content";
import { existsSync } from "node:fs";
import { join } from "node:path";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import OptimizedImage from "../../components/OptimizedImage.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const urlToPublicPath = (url: string) => url.replace(/^\//, "");
const webpUrl = (url: string) => url.replace(/\.[^.]+$/, ".webp");
const hasWebp = (url: string) =>
  existsSync(join(process.cwd(), "public", urlToPublicPath(url).replace(/\.[^.]+$/, ".webp")));
---

<BaseLayout title={`${post.data.title} — Іра`} description={post.data.excerpt}>
  <SiteHeader />

  <main class="page">
    <article class="section blog-post">
      {post.data.cover && (
        <picture>
          {hasWebp(post.data.cover) && <source srcset={webpUrl(post.data.cover)} type="image/webp" />}
          <img
            class="blog-post__cover"
            src={post.data.cover}
            alt={post.data.title}
            loading="eager"
            decoding="async"
          />
        </picture>
      )}

      <header class="blog-post__header" data-reveal>
        <time class="blog-post__date" datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString("uk-UA", {
            day: "numeric",
            month: "long",
            year: "numeric",
          })}
        </time>
        <h1 class="blog-post__title">{post.data.title}</h1>
      </header>

      <div class="blog-post__body prose" data-reveal>
        <Content components={{ img: OptimizedImage }} />
      </div>

      <a href={`${base}blog/`} class="blog-post__back">← Всі пости</a>
    </article>
  </main>

  <footer class="site-footer">
    <p>© {new Date().getFullYear()} Іра — Фотограф</p>
  </footer>
</BaseLayout>
