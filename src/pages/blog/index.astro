---
import { getCollection } from "astro:content";
import { existsSync } from "node:fs";
import { join } from "node:path";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

// Convert absolute URL like /irart_cv/galleries/... → public-relative path
const urlToPublicPath = (url: string) =>
  url.replace(/^\/[^/]+\//, ""); // strip /base/

const webpUrl = (url: string) => url.replace(/\.[^.]+$/, ".webp");

const hasWebp = (url: string) => {
  const rel = urlToPublicPath(url);
  return existsSync(join(process.cwd(), "public", rel.replace(/\.[^.]+$/, ".webp")));
};
---

<BaseLayout title="Блог — Іра">
  <SiteHeader />

  <main class="page">
    <section class="section" style="padding-top: 3.5rem;">
      <div class="section__top" data-reveal>
        <header class="section__head">
          <h1 class="section__title">Блог</h1>
          <p class="section__intro">Поради, спостереження та історії зі зйомок.</p>
        </header>
      </div>

      <div class="blog-grid">
        {posts.map((post, i) => (
          <article class="blog-card" data-reveal style={`--stagger: ${i}`}>
            {post.data.cover && (
              <a href={`${base}blog/${post.slug}/`} class="blog-card__cover">
                <picture>
                  {hasWebp(post.data.cover) && <source srcset={webpUrl(post.data.cover)} type="image/webp" />}
                  <img src={post.data.cover} alt={post.data.title} loading="lazy" decoding="async" />
                </picture>
              </a>
            )}
            <div class="blog-card__body">
              <time class="blog-card__date" datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString("uk-UA", {
                  day: "numeric",
                  month: "long",
                  year: "numeric",
                })}
              </time>
              <h2 class="blog-card__title">
                <a href={`${base}blog/${post.slug}/`}>{post.data.title}</a>
              </h2>
              {post.data.excerpt && <p class="blog-card__excerpt">{post.data.excerpt}</p>}
              <a href={`${base}blog/${post.slug}/`} class="blog-card__read">Читати →</a>
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <p>© {new Date().getFullYear()} Іра — Фотограф</p>
  </footer>
</BaseLayout>
