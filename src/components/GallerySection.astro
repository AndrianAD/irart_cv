---
export interface GalleryItem {
  /** Path under public/, e.g. `galleries/portrait/01.jpg` — any extension (.jpg, .png, .webp). */
  file: string;
  alt: string;
  caption?: string;
  /** Optional; lightbox size is taken from the image file automatically. */
  width?: number;
  height?: number;
  layout?: "feature";
}

interface Props {
  categoryId: string;
  title: string;
  intro: string;
  items: GalleryItem[];
  /** Trailing slash, e.g. import.meta.env.BASE_URL */
  baseUrl: string;
  /** Three equal columns, square tiles (Instagram-style) */
  grid?: "instagram";
}

const { categoryId, title, intro, items, baseUrl, grid } = Astro.props;
const galleryId = `gallery-${categoryId}`;
const isInstagram = grid === "instagram";

import { existsSync } from "node:fs";
import { join } from "node:path";

const hrefFor = (file: string) => `${baseUrl}${file.replace(/^\//, "")}`;
const webpHref = (file: string) => hrefFor(file.replace(/\.[^.]+$/, ".webp"));

/** True only when the optimized .webp exists on disk (generated by scripts/optimize-images.mjs). */
const hasWebp = (file: string) =>
  existsSync(join(process.cwd(), "public", file.replace(/\.[^.]+$/, ".webp")));
---

<section
  class:list={["section", isInstagram && "section--instagram"]}
  id={`section-${categoryId}`}
  aria-labelledby={`heading-${categoryId}`}
  {...(!isInstagram && { "data-reveal": true })}
>
  <div class="section__top" {...(isInstagram && { "data-reveal": true })}>
    <header class="section__head">
      <h2 class="section__title" id={`heading-${categoryId}`}>{title}</h2>
      <p class="section__intro">{intro}</p>
    </header>
  </div>

  {
    isInstagram ? (
      <div class="instagram-bleed">
        <div class:list={["pswp-gallery", "pswp-gallery--instagram"]} id={galleryId}>
          {items.map((item, index) => {
            const href = hrefFor(item.file);
            const stagger = Math.min(index, 14);
            return (
              <figure class="gallery-item" data-reveal-child style={`--stagger: ${stagger}`}>
                <a href={href} {...(item.caption ? { "data-pswp-caption": item.caption } : {})}>
                  <picture>
                    {hasWebp(item.file) && <source srcset={webpHref(item.file)} type="image/webp" />}
                    <img src={href} alt={item.alt} loading="lazy" decoding="async" />
                  </picture>
                </a>
              </figure>
            );
          })}
        </div>
      </div>
    ) : (
      <div class:list={["pswp-gallery"]} id={galleryId}>
        {items.map((item, index) => {
          const href = hrefFor(item.file);
          const layoutClass =
            item.layout === "feature" ? "gallery-item gallery-item--feature" : "gallery-item";
          const stagger = Math.min(index, 14);
          return (
            <figure class={layoutClass} data-reveal-child style={`--stagger: ${stagger}`}>
              <a href={href} {...(item.caption ? { "data-pswp-caption": item.caption } : {})}>
                <picture>
                  {hasWebp(item.file) && <source srcset={webpHref(item.file)} type="image/webp" />}
                  <img src={href} alt={item.alt} loading="lazy" decoding="async" />
                </picture>
              </a>
            </figure>
          );
        })}
      </div>
    )
  }
</section>
